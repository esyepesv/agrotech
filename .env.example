# ── Canales ──────────────────────────────────────────────────────────
# WhatsApp Business Cloud API (Meta). Fase 2 — opcional en dev.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token arbitrario que tú defines; Meta lo repite en el GET de verificación del webhook.
WHATSAPP_VERIFY_TOKEN=
# App Secret de la app de Meta (panel de developers.facebook.com → Configuración básica).
# Si se define, el POST del webhook de WhatsApp verifica la firma X-Hub-Signature-256
# sobre el raw body y responde 401 si falta o no coincide. Opcional (con advertencia
# en logs mientras no esté configurado) para no romper antes de definirlo.
WHATSAPP_APP_SECRET=

# Telegram Bot API (crear con @BotFather). Canal de dev/test — opcional.
TELEGRAM_BOT_TOKEN=

# ── IA ───────────────────────────────────────────────────────────────
# LLM vía OpenRouter (API compatible con OpenAI chat completions).
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4.5

# v1.1 — módulo farm: router de intención y extractor de eventos.
# Mismas credenciales de OpenRouter (LLM_API_KEY); solo se elige el modelo.
# El clasificador corre en cada mensaje → modelo pequeño y barato.
INTENT_MODEL=anthropic/claude-haiku-4.5
EXTRACTOR_MODEL=anthropic/claude-sonnet-4.5

# OpenAI directo: Whisper (STT), TTS y embeddings.
OPENAI_API_KEY=
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Datos (Supabase: Postgres + pgvector) ────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Pepper secreto (≥16 caracteres, p. ej. 64 hex aleatorios) para el HMAC del
# hash de channelUserId en conversation_turn. Requerido (#2 hardening):
# nunca se guarda el identificador del usuario en claro ni con un hash pelado.
USER_ID_SALT=

# ── App ──────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
# Canal activo por defecto: telegram | whatsapp
ACTIVE_CHANNEL=telegram
# Umbral mínimo de similitud (0–1) para aceptar un chunk recuperado como
# contexto válido en el grounding del RAG (#3 hardening). Opcional.
RAG_MIN_SCORE=0.35
# v1.1 — TTL (segundos) del registro pendiente de confirmación: pasado este
# tiempo, un "sí" tardío ya no confirma nada. Opcional.
PENDING_EVENT_TTL_SECONDS=600

# ── v1.2 — Registro de usuario + granja (spec 001) ───────────────────
# TTL (segundos) del borrador de onboarding conversacional. Más largo que
# PENDING_EVENT_TTL_SECONDS: llenar ~10 campos por voz toma su tiempo.
ONBOARDING_PENDING_TTL_SECONDS=1800

# OTP de la app web. El código se guarda solo hasheado (HMAC con USER_ID_SALT).
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_VERIFIED_GRACE_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30
# Solicitudes de código por teléfono y hora (cada envío de WhatsApp cuesta).
OTP_RATE_LIMIT_PER_HOUR=3

# Transportes de OTP adicionales a los canales de chat. Cada bloque es
# opcional: sin credenciales, ese transporte no se le ofrece al usuario.
# SMS (Twilio) es el único que alcanza un número que nunca escribió al bot.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Usa UNO de los dos: un número comprado en Twilio o un Messaging Service.
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Correo por SMTP genérico (cualquier servidor: Gmail corporativo, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remitente visible, ej.: PorcIA <no-reply@porcia.com.co>
SMTP_FROM=
# Destinatario de los contactos recibidos desde porcia-web.
LEAD_NOTIFICATION_TO=porciacol@gmail.com

# Secreto de firma de la sesión web (HS256). REQUERIDO, ≥32 caracteres:
# genera uno con `openssl rand -hex 32`. Sin él el proceso no levanta.
SESSION_JWT_SECRET=
# Vigencia de la sesión emitida al terminar el registro (7 días por defecto).
SESSION_TTL_SECONDS=604800

# Orígenes permitidos para la app de registro, separados por comas.
# Ej.: https://app.porcia.com.co,https://porcia.com.co,http://localhost:5173
CORS_ALLOWED_ORIGINS=
