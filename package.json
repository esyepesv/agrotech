{
  "name": "porcia-backend",
  "version": "0.1.0",
  "description": "Asistente porcícola de conocimiento por voz (WhatsApp/Telegram + RAG)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/interfaces/http/server.ts",
    "start": "node dist/src/interfaces/http/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest": "tsx scripts/ingest-knowledge.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/functions": "^3.7.5",
    "@vercel/node": "^5.8.22",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "openai": "^4.70.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
